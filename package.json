{
  "name": "@metalab/design-sync-pipeline",
  "version": "0.0.9",
  "description": "Local orchestration service that receives Edit events from front-door tools (Storybook addons, Figma plugins) and routes them to write-capable engines.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "design-sync-pipeline": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "serve": "node dist/cli.js serve",
    "dev": "tsc -w -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@metalab/design-sync-core": "github:mylesmetalab/design-sync-core#v0.0.1",
    "postcss": "^8.5.14",
    "ts-morph": "^28.0.0"
  }
}
